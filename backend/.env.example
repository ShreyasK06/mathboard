# Gemini API key — required for handwriting OCR
# Get a FREE key at: aistudio.google.com → "Get API key" → "Create API key"
# IMPORTANT: Must be an AI Studio key, NOT a Google Cloud API key.
# AI Studio keys work immediately without any GCP project configuration.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
